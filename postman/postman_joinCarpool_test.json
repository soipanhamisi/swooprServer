{
  "info": {
    "_postman_id": "swoopd-carpool-tests",
    "name": "Swoopd - Join Carpool Tests",
    "description": "Test collection for Swoopd carpool joining functionality",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Join Carpool - Valid Request",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status code is 200', function() {",
              "  pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test('Response has Trip object', function() {",
              "  var jsonData = pm.response.json();",
              "  pm.expect(jsonData).to.have.property('tripId');",
              "});",
              "",
              "pm.test('Trip has destination zone', function() {",
              "  var jsonData = pm.response.json();",
              "  pm.expect(jsonData).to.have.property('destinationZone');",
              "  pm.expect(jsonData.destinationZone).to.not.be.null;",
              "});",
              "",
              "pm.test('Trip status is OPEN', function() {",
              "  var jsonData = pm.response.json();",
              "  pm.expect(jsonData.tripStatus).to.equal('OPEN');",
              "});",
              "",
              "pm.test('Response time is less than 3000ms', function() {",
              "  pm.expect(pm.response.responseTime).to.be.below(3000);",
              "});"
            ],
            "type": "text/javascript",
            "packages": {}
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{jwt_token}}",
            "type": "text"
          },
          {
            "key": "Content-Type",
            "value": "application/json",
            "type": "text"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"departureTime\": \"2026-07-10T14:30:00\",\n  \"rsOriginDestination\": {\n    \"originLatitude\": -1.2162197157958907,\n    \"originLongitude\": 36.87887962264436,\n    \"destinationLatitude\": -1.3229149986589575,\n    \"destinationLongitude\": 36.66571916682583\n  }\n}"
        },
        "url": {
          "raw": "{{base_url}}/trips/joinCarPool",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "trips",
            "joinCarPool"
          ]
        },
        "description": "Join carpool with valid origin and destination coordinates\n\nOrigin: -1.2162197157958907, 36.87887962264436\nDestination: -1.3229149986589575, 36.66571916682583"
      },
      "response": []
    },
    {
      "name": "Join Carpool - Missing Destination Coordinates (Error Test)",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status code is 400 or 500 (invalid request)', function() {",
              "  pm.expect([400, 500]).to.include(pm.response.code);",
              "});",
              "",
              "pm.test('Response contains error message', function() {",
              "  var responseText = pm.response.text();",
              "  pm.expect(responseText).to.include.oneOf(['null', 'error', 'Error', 'Failed']);",
              "});"
            ],
            "type": "text/javascript",
            "packages": {}
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{jwt_token}}",
            "type": "text"
          },
          {
            "key": "Content-Type",
            "value": "application/json",
            "type": "text"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"departureTime\": \"2026-07-10T14:30:00\",\n  \"rsOriginDestination\": {\n    \"originLatitude\": -1.2162197157958907,\n    \"originLongitude\": 36.87887962264436,\n    \"destinationLatitude\": null,\n    \"destinationLongitude\": null\n  }\n}"
        },
        "url": {
          "raw": "{{base_url}}/trips/joinCarPool",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "trips",
            "joinCarPool"
          ]
        },
        "description": "Testing error handling when destination coordinates are null"
      },
      "response": []
    },
    {
      "name": "Join Carpool - Missing JWT (Auth Error Test)",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status code is 401 Unauthorized', function() {",
              "  pm.expect(pm.response.code).to.equal(401);",
              "});"
            ],
            "type": "text/javascript",
            "packages": {}
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json",
            "type": "text"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"departureTime\": \"2026-07-10T14:30:00\",\n  \"rsOriginDestination\": {\n    \"originLatitude\": -1.2162197157958907,\n    \"originLongitude\": 36.87887962264436,\n    \"destinationLatitude\": -1.3229149986589575,\n    \"destinationLongitude\": 36.66571916682583\n  }\n}"
        },
        "url": {
          "raw": "{{base_url}}/trips/joinCarPool",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "trips",
            "joinCarPool"
          ]
