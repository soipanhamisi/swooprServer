        "description": "Testing authentication requirement"
      },
      "response": []
    },
    {
      "name": "Join Carpool - Different Departure Time",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status code is 200 or 400 (depends on trip availability)', function() {",
              "  pm.expect([200, 400]).to.include(pm.response.code);",
              "});",
              "",
              "if (pm.response.code === 200) {",
              "  pm.test('Response has Trip object if trip found', function() {",
              "    var jsonData = pm.response.json();",
              "    pm.expect(jsonData).to.have.property('tripId');",
              "  });",
              "} else {",
              "  pm.test('Response indicates no available trip', function() {",
              "    var responseText = pm.response.text();",
              "    pm.expect(responseText.toLowerCase()).to.include('no available');",
              "  });",
              "}"
            ],
            "type": "text/javascript",
            "packages": {}
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{jwt_token}}",
            "type": "text"
          },
          {
            "key": "Content-Type",
            "value": "application/json",
            "type": "text"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"departureTime\": \"2026-07-11T10:00:00\",\n  \"rsOriginDestination\": {\n    \"originLatitude\": -1.2162197157958907,\n    \"originLongitude\": 36.87887962264436,\n    \"destinationLatitude\": -1.3229149986589575,\n    \"destinationLongitude\": 36.66571916682583\n  }\n}"
        },
        "url": {
          "raw": "{{base_url}}/trips/joinCarPool",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "trips",
            "joinCarPool"
          ]
        },
        "description": "Testing with a different departure time (tomorrow)"
      },
      "response": []
    }
  ],
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:8080",
      "type": "string",
      "description": "Base URL for Swoopd API - update for GCP deployment"
    },
    {
      "key": "jwt_token",
      "value": "",
